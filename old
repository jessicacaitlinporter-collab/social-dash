// ═══════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════
const state = {
  period0:'week', handle0:'all',
  period1:'week', partisan:'all',
  period2:'week',
  competitors: ['@larryhogan','@brandanarundel'],
  alertPanelOpen: false
};

const PLATFORMS = ['Facebook','Instagram','X','YouTube','TikTok'];
const PCOLORS = { Facebook:'#1877f2', Instagram:'#e1306c', X:'#e7e9ea', YouTube:'#ff0000', TikTok:'#69c9d0' };
const PCLS = { Facebook:'fb', Instagram:'ig', X:'x', YouTube:'yt', TikTok:'tt' };

// ═══════════════════════════════════════════════
//  SEED DATA GENERATOR
// ═══════════════════════════════════════════════
function rand(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }
function fmtN(n){ if(n>=1e6) return (n/1e6).toFixed(1)+'M'; if(n>=1e3) return (n/1e3).toFixed(1)+'K'; return n; }
function fmtPct(n){ return (n*100).toFixed(2)+'%'; }
function daysAgo(d){ const dt=new Date(); dt.setDate(dt.getDate()-d); return dt.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'}); }

// Platform followers per handle
const FOLLOWERS = {
  '@govwesmoore':{ Facebook:420000, Instagram:310000, X:285000, YouTube:95000, TikTok:187000 },
  '@iamwesmoore':{ Facebook:188000, Instagram:249000, X:204000, YouTube:61000, TikTok:320000 }
};

const POST_SAMPLES = {
  Facebook:["Proud to sign HB 1111 into law today — expanding broadband to every corner of Maryland.","We're investing in Maryland's future. Here's what our latest budget means for families.","Honored to welcome @POTUS to Annapolis this week."],
  Instagram:["📸 Behind the scenes at today's ribbon cutting in Baltimore.","Black business owners in Maryland are building something real. We're here to support them. 🙌","Our commitment to education reform is unwavering. Here's the progress."],
  X:["Just signed an executive order directing state agencies to reduce emissions 45% by 2030.","Maryland families deserve relief. We delivered.","Grateful for the warm welcome in Prince George's County today."],
  YouTube:["Governor Moore Full Address: Investing in Maryland's Future","Wes Moore Interview: Education, Housing & the Economy Explained","Official: Governor Moore Signs Criminal Justice Reform Package"],
  TikTok:["POV: You're the Governor of Maryland and you just signed the biggest climate bill in state history 🌱","Real talk with real Marylanders — what do YOU want from your government?","Day in the life of Governor Moore 🔥"]
};

function makePost(handle, platform, daysAgoVal, engMultiplier=1){
  const followers = FOLLOWERS[handle][platform];
  const isVideo = platform==='YouTube'||platform==='TikTok'||(Math.random()>0.6);
  let likes=0,comments=0,views=0,engRate;
  if(isVideo){
    views = rand(followers*0.05, followers*0.8)*engMultiplier;
    engRate = views/followers;
  } else {
    likes = rand(500, followers*0.05)*engMultiplier;
    comments = rand(50, likes*0.15)*engMultiplier;
    engRate = (likes+comments)/followers;
  }
  const previews = POST_SAMPLES[platform];
  return { handle, platform, text:previews[rand(0,previews.length-1)], likes, comments, views, engRate, followers, isVideo, date:daysAgo(daysAgoVal), breakout: engMultiplier>=3 };
}

function generateOwnPosts(period){
  const days = {y24h:1, week:7, month:30, year:365}[period] || 7;
  const posts = [];
  const handles = ['@govwesmoore','@iamwesmoore'];
  handles.forEach(h=>{
    PLATFORMS.forEach(p=>{
      for(let i=0;i<rand(2,5);i++){
        const mult = Math.random()>0.85?rand(3,8):1;
        posts.push(makePost(h,p,rand(0,days),mult));
      }
    });
  });
  return posts.sort((a,b)=>b.engRate-a.engRate);
}

const MENTION_ACCOUNTS = [
  {handle:'@WBALNews',platform:'X',partisan:'center'},
  {handle:'@BaltimoreSD',platform:'Facebook',partisan:'left'},
  {handle:'@MDRepublicans',platform:'X',partisan:'right'},
  {handle:'@CBSBaltimore',platform:'YouTube',partisan:'center'},
  {handle:'@mdpoliticsnow',platform:'TikTok',partisan:'unknown'},
  {handle:'@AfroAmericaNews',platform:'Instagram',partisan:'left'},
  {handle:'@NationalReview',platform:'X',partisan:'right'},
  {handle:'@GovWatchMD',platform:'Facebook',partisan:'center'},
  {handle:'@ProgressiveMD',platform:'Instagram',partisan:'left'},
  {handle:'@MDConservative',platform:'TikTok',partisan:'right'},
  {handle:'@WTOP',platform:'X',partisan:'center'},
  {handle:'@CityPaperBmore',platform:'Instagram',partisan:'left'},
];
const MENTION_TEXTS = [
  'Governor Moore announced a major infrastructure push — biggest in MD history.',
  'Moore signs sweeping criminal justice reform: what it means for Maryland.',
  'Not everyone agrees with Governor Moore\'s new education policy.',
  'Wes Moore makes his case for a second term in major speech today.',
  'Breaking: Moore administration releases new climate action plan.',
  'Governor Moore meets with local union leaders amid budget talks.',
  'The Moore record: a look at promises made vs. promises kept.',
  'Moore\'s approval rating hits new high, poll shows.',
  'Critics say Governor Moore\'s housing plan falls short.',
  'VIDEO: Wes Moore speaks at NAACP convention, crowd goes wild.',
];

function generateMentions(){
  const mentions = [];
  MENTION_ACCOUNTS.forEach((acc,i)=>{
    const isVideo = acc.platform==='YouTube'||acc.platform==='TikTok';
    const followers = rand(5000,800000);
    const mult = Math.random()>0.8?rand(2,6):1;
    let likes=0,comments=0,views=0,engRate;
    if(isVideo){ views=rand(1000,followers*0.6)*mult; engRate=views/followers; }
    else { likes=rand(100,followers*0.04)*mult; comments=rand(10,likes*0.2)*mult; engRate=(likes+comments)/followers; }
    const sentiments = ['positive','neutral','negative'];
    mentions.push({ ...acc, followers, text:MENTION_TEXTS[i%MENTION_TEXTS.length], likes, comments, views, engRate, sentiment:sentiments[rand(0,2)], date:daysAgo(rand(0,30)), daysAgoVal:rand(0,30) });
  });
  return mentions;
}

// ═══════════════════════════════════════════════
//  CHART.JS INSTANCES
// ═══════════════════════════════════════════════
let charts = {};
function destroyChart(id){ if(charts[id]){ charts[id].destroy(); delete charts[id]; } }

const CHART_DEFAULTS = {
  plugins:{ legend:{ labels:{ color:'#8892a4', font:{family:'Instrument Sans',size:11}, boxWidth:10 } } },
  scales:{
    x:{ ticks:{color:'#4e5970',font:{size:10}}, grid:{color:'rgba(37,43,56,0.8)'} },
    y:{ ticks:{color:'#4e5970',font:{size:10}}, grid:{color:'rgba(37,43,56,0.8)'} }
  }
};

function mergeDeep(a,b){ return Object.assign({},a,b, a.scales&&b.scales?{scales:Object.assign({},a.scales,b.scales)}:{}); }

function buildLabel(period){
  const n = {y24h:24,week:7,month:30,year:12}[period]||7;
  const unit = {y24h:'hr',week:'d',month:'d',year:'mo'}[period]||'d';
  return Array.from({length:n},(_,i)=>unit==='hr'?`${i+1}h`:`-${n-i}${unit}`);
}

function buildEngagementChart(posts){
  destroyChart('eng');
  const ctx = document.getElementById('engagementChart').getContext('2d');
  const byPlatform = {};
  PLATFORMS.forEach(p=>{ byPlatform[p]=[]; });
  posts.forEach(post=>{ byPlatform[post.platform].push(post.engRate); });
  const avgs = PLATFORMS.map(p=>byPlatform[p].length? byPlatform[p].reduce((a,b)=>a+b,0)/byPlatform[p].length:0);
  charts['eng'] = new Chart(ctx, {
    type:'bar',
    data:{
      labels: PLATFORMS,
      datasets:[{ label:'Avg Engagement Rate', data:avgs.map(v=>+(v*100).toFixed(3)),
        backgroundColor: PLATFORMS.map(p=>PCOLORS[p]+'99'), borderColor: PLATFORMS.map(p=>PCOLORS[p]),
        borderWidth:1.5, borderRadius:6 }]
    },
    options:{ ...CHART_DEFAULTS, plugins:{...CHART_DEFAULTS.plugins,tooltip:{callbacks:{label:c=>`${c.parsed.y.toFixed(3)}%`}}},
      scales:{...CHART_DEFAULTS.scales, y:{...CHART_DEFAULTS.scales.y, ticks:{...CHART_DEFAULTS.scales.y.ticks, callback:v=>v+'%'}}} }
  });
}

function buildFollowerChart(period){
  destroyChart('fol');
  const ctx = document.getElementById('followerChart').getContext('2d');
  const labels = buildLabel(period);
  const datasets = ['@govwesmoore','@iamwesmoore'].map((h,i)=>({
    label:h, data:labels.map(()=>rand(200,4000)),
    borderColor: i===0?'#4f7fff':'#7c5cfc', backgroundColor: i===0?'rgba(79,127,255,0.08)':'rgba(124,92,252,0.08)',
    tension:0.4, fill:true, pointRadius:2
  }));
  charts['fol'] = new Chart(ctx, { type:'line', data:{labels,datasets}, options:{...CHART_DEFAULTS} });
}

function buildContentTypeChart(posts){
  destroyChart('ctype');
  const ctx = document.getElementById('contentTypeChart').getContext('2d');
  const textPosts = posts.filter(p=>!p.isVideo);
  const vidPosts = posts.filter(p=>p.isVideo);
  const textAvg = textPosts.length? textPosts.reduce((a,b)=>a+b.engRate,0)/textPosts.length:0;
  const vidAvg = vidPosts.length? vidPosts.reduce((a,b)=>a+b.engRate,0)/vidPosts.length:0;
  charts['ctype'] = new Chart(ctx, {
    type:'doughnut',
    data:{
      labels:['Text/Image Posts','Video Posts'],
      datasets:[{ data:[(textAvg*100).toFixed(3),(vidAvg*100).toFixed(3)],
        backgroundColor:['rgba(79,127,255,0.8)','rgba(124,92,252,0.8)'],
        borderColor:['#4f7fff','#7c5cfc'], borderWidth:2, hoverOffset:8 }]
    },
    options:{ plugins:{...CHART_DEFAULTS.plugins, tooltip:{callbacks:{label:c=>`${c.label}: ${c.parsed.toFixed(3)}%`}}}, cutout:'65%' }
  });
}

function buildCompFollowerChart(period){
  destroyChart('compFol');
  const ctx = document.getElementById('compFollowerChart').getContext('2d');
  const labels = buildLabel(period);
  const colors = ['#4f7fff','#7c5cfc','#2dd4a0','#e8b84b','#ff4f6a','#ff8c42'];
  const allHandles = ['Moore (@govwesmoore + @iamwesmoore)', ...state.competitors];
  const datasets = allHandles.map((h,i)=>({
    label:h, data:labels.map(()=>rand(300,8000)*(i===0?2:1)),
    borderColor:colors[i%colors.length], backgroundColor:colors[i%colors.length]+'15',
    tension:0.4, fill:i===0, pointRadius:2
  }));
  charts['compFol'] = new Chart(ctx, { type:'line', data:{labels,datasets}, options:{...CHART_DEFAULTS} });
}

// ═══════════════════════════════════════════════
//  RENDER STAT CARDS
// ═══════════════════════════════════════════════
function renderStatCards(posts){
  const container = document.getElementById('statsRow0');
  container.innerHTML='';
  const byPlatform={};
  PLATFORMS.forEach(p=>byPlatform[p]={engRates:[],followers:0});
  posts.forEach(p=>{ byPlatform[p.platform].engRates.push(p.engRate); byPlatform[p.platform].followers=Math.max(byPlatform[p.platform].followers, p.followers); });
  const totalPosts = posts.length;
  const overallEng = posts.reduce((a,b)=>a+b.engRate,0)/Math.max(posts.length,1);
  const overallFollowers = Object.values(FOLLOWERS).flatMap(h=>Object.values(h)).reduce((a,b)=>a+b,0);
  const cards = [
    {label:'Total Followers',value:fmtN(overallFollowers),change:'+2.3%',dir:'up',platform:'All Platforms'},
    {label:'Avg Eng. Rate',value:fmtPct(overallEng),change:'+0.4pp',dir:'up',platform:'All Platforms'},
    {label:'Posts Analyzed',value:totalPosts,change:'—',dir:'',platform:'Selected Period'},
    {label:'Top Platform',value:'Instagram',change:'3.21%',dir:'up',platform:'Highest Eng. Rate'},
  ];
  cards.forEach(c=>{
    const el = document.createElement('div');
    el.className='stat-card';
    el.innerHTML=`
      <div class="stat-platform"><span class="stat-label">${c.label}</span></div>
      <div class="stat-value">${c.value}</div>
      <div class="stat-change ${c.dir}">${c.dir==='up'?'↑':c.dir==='down'?'↓':''} ${c.change} &nbsp;<span style="color:var(--text3);font-weight:400">${c.platform}</span></div>`;
    container.appendChild(el);
  });
}

