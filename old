        const tr=document.createElement('tr');
        tr.innerHTML=`
          <td>${platformTag(p)}</td>
          <td>${handleChip(handle)}</td>
          <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${COMP_POST_TEXTS[rand(0,COMP_POST_TEXTS.length-1)]}</td>
          <td class="strong">${fmtPct(engRate)}</td>
          <td style="color:var(--orange);font-weight:700">+${mult}× avg</td>
          <td><span class="breakout-badge"><svg viewBox="0 0 10 10"><polygon points="5,1 9,9 1,9"/></svg>RISING</span></td>
          <td>${daysAgo(rand(0,7))}</td>`;
        breakoutBody.appendChild(tr);
      }
    });
  });
  
  // Top
  const topBody = document.getElementById('compTopBody');
  topBody.innerHTML='';
  all.forEach(handle=>{
    PLATFORMS.forEach(p=>{
      const isVideo = p==='YouTube'||p==='TikTok';
      const followers=rand(50000,500000);
      const likes=isVideo?0:rand(500,20000);
      const comments=isVideo?0:rand(50,likes*0.15);
      const views=isVideo?rand(10000,500000):0;
      const engRate=isVideo?views/followers:(likes+comments)/followers;
      const tr=document.createElement('tr');
      tr.innerHTML=`
        <td>${platformTag(p)}</td>
        <td>${handleChip(handle)}</td>
        <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${COMP_POST_TEXTS[rand(0,COMP_POST_TEXTS.length-1)]}</td>
        <td>${fmtN(likes)||'—'}</td>
        <td>${fmtN(comments)||'—'}</td>
        <td>${views?fmtN(views):'—'}</td>
        <td class="strong">${fmtPct(engRate)}</td>
        <td>${daysAgo(rand(0,30))}</td>`;
      topBody.appendChild(tr);
    });
  });
}

// ═══════════════════════════════════════════════
//  ALERT PANEL & NOTIFICATIONS
// ═══════════════════════════════════════════════
function populateAlerts(){
  const list = document.getElementById('alertList');
  const alerts = [
    {platform:'TikTok',handle:'@iamwesmoore',text:'New video hitting 12× avg engagement — climate bill signing.',metric:'Engagement: 8.2% (avg 0.6%)',time:'4 min ago'},
    {platform:'X',handle:'@govwesmoore',text:'Tweet on criminal justice reform trending in MD.',metric:'Velocity: 2.3K engagements/hr',time:'22 min ago'},
    {platform:'Instagram',handle:'@larryhogan',text:'Competitor post gaining rapid traction statewide.',metric:'Engagement: 6.1% (avg 1.0%)',time:'1h ago'},
    {platform:'YouTube',handle:'@CBSBaltimore',text:'Mention of Governor Moore in viral news clip.',metric:'Views: 180K in 3 hours',time:'2h ago'},
  ];
  list.innerHTML = alerts.map(a=>`
    <div class="alert-item">
      <div class="alert-item-head">
        <span class="alert-item-platform" style="color:${PCOLORS[a.platform]}">${a.platform} · ${a.handle}</span>
        <span class="alert-item-time">${a.time}</span>
      </div>
      <div class="alert-item-text">${a.text}</div>
      <div class="alert-item-metric">⚡ ${a.metric}</div>
    </div>`).join('');
}

function toggleAlerts(){
  state.alertPanelOpen = !state.alertPanelOpen;
  document.getElementById('alertPanel').classList.toggle('open', state.alertPanelOpen);
}

function saveAlertConfig(){
  const email = document.getElementById('alertEmail').value;
  if(email) alert(`✓ Breakout alerts will be sent to ${email}`);
  else alert('Enter an email address first.');
}

// ═══════════════════════════════════════════════
//  TAB & FILTER LOGIC
// ═══════════════════════════════════════════════
const tabs = document.querySelectorAll('.tab');
const pages = document.querySelectorAll('.page');

function switchTab(i){
  tabs.forEach((t,j)=>t.classList.toggle('active',i===j));
  pages.forEach((p,j)=>p.classList.toggle('active',i===j));
}

function setFilter(key, val, btn){
  state[key] = val;
  const group = btn.parentElement;
  group.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  refreshTab0();
  refreshTab2();
}

function setPartisan(val, btn){
  state.partisan = val;
  const group = btn.parentElement;
  group.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('partisanSubLabel').textContent = `Filtered by: ${val==='all'?'All Lean':'Partisan lean = '+val.charAt(0).toUpperCase()+val.slice(1)} · newest first`;
  renderMentions(window._mentions, state.partisan);
}

// ═══════════════════════════════════════════════
//  REFRESH FUNCTIONS
// ═══════════════════════════════════════════════
function refreshTab0(){
  let posts = generateOwnPosts(state.period0);
  if(state.handle0==='gov') posts=posts.filter(p=>p.handle==='@govwesmoore');
  if(state.handle0==='iam') posts=posts.filter(p=>p.handle==='@iamwesmoore');
  renderStatCards(posts);
  buildEngagementChart(posts);
  buildFollowerChart(state.period0);
  buildContentTypeChart(posts);
  renderBestPosts(posts);
}

function refreshTab2(){
  buildCompFollowerChart(state.period2);
  renderCompetitorTables();
}

// ═══════════════════════════════════════════════
//  COMPETITOR MANAGEMENT
// ═══════════════════════════════════════════════
function addCompetitor(){
  let val = document.getElementById('competitorInput').value.trim();
  if(!val) return;
  if(!val.startsWith('@')) val='@'+val;
  if(!state.competitors.includes(val)){
    state.competitors.push(val);
    renderCompetitorChips();
    refreshTab2();
  }
  document.getElementById('competitorInput').value='';
}

function removeCompetitor(handle){
  state.competitors = state.competitors.filter(c=>c!==handle);
  renderCompetitorChips();
  refreshTab2();
}

function renderCompetitorChips(){
  const el = document.getElementById('competitorChips');
  el.innerHTML = state.competitors.map(h=>`
    <div class="competitor-chip">${h}
      <button onclick="removeCompetitor('${h}')" title="Remove">×</button>
    </div>`).join('');
}

// ═══════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════
function initDashboard(){
  window._mentions = generateMentions();
  renderCompetitorChips();
  refreshTab0();
  renderMentions(window._mentions, 'all');
  refreshTab2();
  populateAlerts();
}
</script>
